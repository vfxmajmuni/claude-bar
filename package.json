{
  "name": "claude-bar",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --mac dir",
    "dist": "electron-builder --mac dmg"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.claudebar.app",
    "productName": "Claude Bar",
    "files": [
      "main.js",
      "preload.js",
      "preload-scraper.js",
      "index.html",
      "renderer.js",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [{"target": "dir", "arch": ["universal"]}]
    },
    "directories": {
      "output": "dist"
    }
  }
}
